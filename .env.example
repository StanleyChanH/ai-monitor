# AI Monitor 环境变量配置示例
# 复制此文件为 .env 并根据需要修改配置

# 摄像头配置
MONITOR_CAM_URL=http://127.0.0.1:8080/shot.jpg
MONITOR_CAM_TIMEOUT=10.0                 # 摄像头连接超时（秒）
MONITOR_CAM_RECONNECT_ENABLED=true      # 启用自动重连
MONITOR_CAM_RECONNECT_DELAY=2.0          # 初始重连延迟（秒）
MONITOR_CAM_RECONNECT_MAX_DELAY=60.0     # 最大重连延迟（秒）

# Ollama 配置
MONITOR_OLLAMA_API=http://10.167.1.223:11434/api/generate
MONITOR_MODEL_NAME=qwen3-vl:4b-instruct-q4_K_M
MONITOR_INFERENCE_TIMEOUT=30.0

# 性能配置
MONITOR_TARGET_WIDTH=640
MONITOR_DETECTION_INTERVAL=2.0              # 推理间隔（秒），控制调用 Ollama 的频率
MONITOR_FRAME_QUEUE_SIZE=2
MONITOR_PROCESSED_QUEUE_SIZE=1

# 告警配置
MONITOR_WEBHOOK_URL=
MONITOR_WEBHOOK_TIMEOUT=5.0
MONITOR_ALERT_COOLDOWN=60
MONITOR_ENABLE_TERMUX_ALERTS=true

# 日志配置
MONITOR_LOG_DIR=./logs
MONITOR_LOG_LEVEL=INFO
MONITOR_LOG_MAX_BYTES=10485760    # 10 MB (单个日志文件最大大小)
MONITOR_LOG_BACKUP_COUNT=5         # 保留 5 个备份文件

# 告警图片配置
MONITOR_ALERT_IMAGE_DIR=./alerts
MONITOR_SAVE_ALERT_IMAGES=true

# 重试配置
MONITOR_MAX_RETRIES=3
MONITOR_RETRY_BASE_DELAY=1.0
MONITOR_RETRY_MAX_DELAY=10.0

# 熔断器配置
MONITOR_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
MONITOR_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
MONITOR_CIRCUIT_BREAKER_TIMEOUT=60.0
