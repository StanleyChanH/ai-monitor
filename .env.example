# ============================================================
# AI Monitor 环境变量配置示例
# 复制此文件为 .env 并根据需要修改配置
# ============================================================

# ------------------------------------------------------------
# 摄像头配置
# ------------------------------------------------------------
# IP Webcam 的照片端点地址，格式通常为 http://<IP>:<PORT>/shot.jpg
MONITOR_CAM_URL=http://127.0.0.1:8080/shot.jpg

# 摄像头连接超时时间（秒），网络不稳定时可适当增大
MONITOR_CAM_TIMEOUT=10.0

# 摄像头断开后是否自动重连，建议保持开启
MONITOR_CAM_RECONNECT_ENABLED=true

# 自动重连的初始延迟（秒），后续会指数增长
MONITOR_CAM_RECONNECT_DELAY=2.0

# 自动重连的最大延迟（秒），防止等待时间过长
MONITOR_CAM_RECONNECT_MAX_DELAY=60.0

# ------------------------------------------------------------
# Ollama 配置
# ------------------------------------------------------------
# Ollama API 地址，可以是本地或局域网内的服务器
MONITOR_OLLAMA_API=http://10.167.1.223:11434/api/generate

# 视觉模型名称，需要先在 Ollama 中 pull 该模型
# 推荐模型：qwen3-vl:4b-instruct-q4_K_M（平衡效果和速度）
# 其他选择：llava:7b-v1.6-q4_K_M、minicpm-v:8b-q4_K_M
MONITOR_MODEL_NAME=qwen3-vl:4b-instruct-q4_K_M

# 推理超时时间（秒），模型响应慢时可适当增大
MONITOR_INFERENCE_TIMEOUT=30.0

# ------------------------------------------------------------
# 性能配置
# ------------------------------------------------------------
# 图像缩放目标宽度（像素），越小传输越快但识别精度降低
MONITOR_TARGET_WIDTH=640

# 推理间隔（秒），控制调用 Ollama 的频率
# 值越大越省电省流量，但可能漏检；建议 1.0-5.0
MONITOR_DETECTION_INTERVAL=2.0

# 原始帧队列大小，队列满时丢弃旧帧
MONITOR_FRAME_QUEUE_SIZE=2

# 处理后帧队列大小，通常设为 1 即可
MONITOR_PROCESSED_QUEUE_SIZE=1

# ------------------------------------------------------------
# 告警配置
# ------------------------------------------------------------
# Webhook 地址，用于推送告警到飞书/钉钉/企业微信等
# 留空则不启用 Webhook 告警
MONITOR_WEBHOOK_URL=

# Webhook 请求超时时间（秒）
MONITOR_WEBHOOK_TIMEOUT=5.0

# 告警冷却时间（秒），防止同一事件重复告警
MONITOR_ALERT_COOLDOWN=60

# 是否启用 Termux 系统告警（震动、通知、Toast）
# 需要安装 Termux:API 应用
MONITOR_ENABLE_TERMUX_ALERTS=true

# ------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------
# 日志文件目录
MONITOR_LOG_DIR=./logs

# 日志级别：DEBUG、INFO、WARNING、ERROR、CRITICAL
MONITOR_LOG_LEVEL=INFO

# 单个日志文件最大大小（字节），超过后自动轮转
# 10485760 = 10 MB
MONITOR_LOG_MAX_BYTES=10485760

# 保留的日志备份文件数量
MONITOR_LOG_BACKUP_COUNT=5

# ------------------------------------------------------------
# 告警图片配置
# ------------------------------------------------------------
# 告警图片保存目录
MONITOR_ALERT_IMAGE_DIR=./alerts

# 是否保存告警截图，用于事后查看证据
MONITOR_SAVE_ALERT_IMAGES=true

# ------------------------------------------------------------
# 重试配置（当前未启用，预留）
# ------------------------------------------------------------
# 最大重试次数
MONITOR_MAX_RETRIES=3

# 重试初始延迟（秒）
MONITOR_RETRY_BASE_DELAY=1.0

# 重试最大延迟（秒）
MONITOR_RETRY_MAX_DELAY=10.0

# ------------------------------------------------------------
# 熔断器配置
# ------------------------------------------------------------
# 连续失败多少次后触发熔断，停止请求 Ollama API
MONITOR_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# 熔断恢复后，连续成功多少次才完全关闭熔断
MONITOR_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2

# 熔断后等待多久尝试恢复（秒）
MONITOR_CIRCUIT_BREAKER_TIMEOUT=60.0
